{
  "config": {
    "step": {
      "user": {
        "title": "Select source integrations",
        "description": "Choose which integrations the hub should aggregate. Detected integrations are pre-selected.",
        "data": {
          "sources": "Source integrations"
        },
        "data_description": {
          "sources": "Select one or more of the three Huawei solar integrations you have installed."
        }
      },
      "priority": {
        "title": "Set source priority",
        "description": "Order the sources from highest to lowest priority. The hub always uses the highest-priority source that is currently available.",
        "data": {
          "priority_0": "Priority 1 (highest)",
          "priority_1": "Priority 2",
          "priority_2": "Priority 3"
        }
      },
      "controls": {
        "title": "Aggregate control entities",
        "description": "The source integrations (Huawei Solar via Modbus) expose writable controls: inverter on/off, battery working mode, charge from grid, power setpoints, forcible charge, and others.\n\n**We recommend leaving this OFF.** Controls exist only on the Modbus connection — there is no cloud equivalent to fail over to, so duplicating them provides no resilience benefit and creates two entities that do the same thing, which can be confusing in automations and dashboards.\n\nEnable this only if you specifically want your dashboards and automations to reference `hf_hub` entities exclusively, including controls. The hub entities (switch, select, number, button) mirror the source state and forward every command to the original entity.",
        "data": {
          "aggregate_controls": "Aggregate switch and select entities"
        }
      }
    },
    "error": {
      "no_sources": "Select at least one source integration.",
      "duplicate_priority": "Each source can appear only once in the priority list."
    },
    "abort": {
      "already_configured": "Huawei Fusion Hub is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Huawei Fusion Hub options",
        "description": "Add or remove source integrations and configure alert behavior. If more than one source is selected, you will be asked to set the priority order.",
        "data": {
          "sources": "Active source integrations",
          "notify_on_disconnect": "Notify when a source goes offline"
        },
        "data_description": {
          "sources": "You can add or remove sources at any time. Removing a source deletes its contribution from the hub without affecting the source integration itself.",
          "notify_on_disconnect": "Shows a persistent notification in Home Assistant when a source becomes unavailable or comes back online."
        }
      },
      "priority": {
        "title": "Update source priority",
        "description": "Order the sources from highest to lowest priority. The hub always uses the highest-priority source that is currently available.",
        "data": {
          "priority_0": "Priority 1 (highest)",
          "priority_1": "Priority 2",
          "priority_2": "Priority 3"
        }
      },
      "controls": {
        "title": "Aggregate control entities",
        "description": "The source integrations (Huawei Solar via Modbus) expose writable controls: inverter on/off, battery working mode, charge from grid, power setpoints, forcible charge, and others.\n\n**We recommend leaving this OFF.** Controls exist only on the Modbus connection — there is no cloud equivalent to fail over to, so duplicating them provides no resilience benefit and creates two entities that do the same thing, which can be confusing in automations and dashboards.\n\nEnable this only if you specifically want your dashboards and automations to reference `hf_hub` entities exclusively, including controls. The hub entities (switch, select, number, button) mirror the source state and forward every command to the original entity.",
        "data": {
          "aggregate_controls": "Aggregate switch and select entities"
        }
      }
    },
    "error": {
      "no_sources": "Select at least one source integration.",
      "duplicate_priority": "Each source can appear only once in the priority list."
    }
  },
