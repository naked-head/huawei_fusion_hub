      "already_configured": "Huawei Fusion Hub è già configurato."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Opzioni Huawei Fusion Hub",
        "description": "Aggiungi o rimuovi integrazioni sorgente e configura gli avvisi. Se vengono selezionate più sorgenti, verrà richiesto di impostare l'ordine di priorità.",
